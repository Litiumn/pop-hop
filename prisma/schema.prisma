generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  VENDOR
  ORGANIZER
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      Role
  createdAt DateTime @default(now())

  events Event[]
  applications Application[]
  booths Booth[]
}

model Event {
  id          String   @id @default(uuid())
  title       String
  description String?
  date        DateTime
  boothLimit  Int
  price       Float
  createdAt   DateTime @default(now())

  organizerId String
  organizer   User @relation(fields: [organizerId], references: [id])

  applications Application[]
  booths Booth[]
  announcements Announcement[]
}

model Application {
  id        String   @id @default(uuid())
  status    ApplicationStatus @default(PENDING)
  createdAt DateTime @default(now())

  userId  String
  eventId String

  user  User  @relation(fields: [userId], references: [id])
  event Event @relation(fields: [eventId], references: [id])

  boothId String?
  booth   Booth? @relation(fields: [boothId], references: [id])

  paymentProof String?      // image URL
  paymentStatus String @default("UNPAID") // UNPAID | PENDING | VERIFIED | REJECTED

  @@unique([userId, eventId])
}

model Booth {
  id        String  @id @default(uuid())
  number    Int

  eventId String
  event   Event @relation(fields: [eventId], references: [id])

  vendorId String?
  vendor   User? @relation(fields: [vendorId], references: [id])

  applications Application[]

  @@unique([eventId, number])
  @@unique([eventId, vendorId])
}

model Announcement {
  id        String   @id @default(uuid())
  title     String
  content   String
  createdAt DateTime @default(now())

  eventId String
  event   Event @relation(fields: [eventId], references: [id])
}